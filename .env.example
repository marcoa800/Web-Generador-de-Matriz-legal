# ─────────────────────────────────────────────
#  Gemini (Google AI Studio)
# ─────────────────────────────────────────────
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────
#  Google Service Account (backend / server)
#  Paste the entire JSON content as a single-line string
# ─────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─────────────────────────────────────────────
#  Google Drive
# ─────────────────────────────────────────────
# ID of the Drive folder where matrices will be saved
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# (Optional) ID of a Google Sheets template to copy instead of creating blank
# GOOGLE_SHEETS_TEMPLATE_ID=your_template_sheet_id_here

# ─────────────────────────────────────────────
#  Server
# ─────────────────────────────────────────────
PORT=3001
